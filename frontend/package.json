{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation next dev",
    "build": "NODE_OPTIONS=--no-deprecation next build",
    "start": "NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "test": "NODE_OPTIONS=--no-deprecation jest",
    "test:watch": "NODE_OPTIONS=--no-deprecation jest --watch",
    "test:ci": "NODE_OPTIONS=--no-deprecation jest --ci",
    "test:coverage": "NODE_OPTIONS=--no-deprecation jest --coverage && node scripts/coverage-summary.cjs",
    "e2e:clean": "rm -rf playwright-report test-results blob-report",
    "e2e:modules": "npm run e2e:clean && node ./scripts/e2e-modules.cjs",
    "e2e:module": "npm run e2e:clean && node ./scripts/e2e-module.cjs",
    "e2e:coverage": "npm run e2e:clean && npm run test:e2e",
    "e2e:coverage:module": "npm run e2e:clean && node ./scripts/e2e-coverage-module.cjs",
    "e2e": "playwright test",
    "e2e:desktop": "playwright test --project=\"Desktop Chrome\"",
    "e2e:mobile": "playwright test --project=\"Mobile Chrome\"",
    "e2e:tablet": "playwright test --project=\"Tablet\"",
    "test:e2e": "playwright test",
    "test:e2e:1": "playwright test e2e/public/smoke.spec.ts e2e/public/navigation.spec.ts e2e/public/blogs.spec.ts",
    "test:e2e:2": "playwright test e2e/public/products.spec.ts e2e/app/user-flows.spec.ts",
    "test:e2e:3": "playwright test e2e/auth/auth.spec.ts",
    "test:e2e:4": "playwright test e2e/app/cart.spec.ts e2e/app/checkout.spec.ts e2e/app/complete-purchase.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "@types/react-google-recaptcha": "^2.1.9",
    "@uiw/react-md-editor": "^4.1.0",
    "axios": "^1.16.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "js-cookie": "^3.0.7",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-google-recaptcha": "^3.1.0",
    "recharts": "^3.8.1",
    "swiper": "^12.1.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-playwright": "^2.10.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": "^10.2.4",
    "flatted": "^3.4.0"
  }
}
