# API Configuration (optional - defaults to /api which uses Next.js rewrites)
NEXT_PUBLIC_API_BASE_URL=/api

# Django backend origin used by Next.js rewrites and media proxy
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000

# Wompi payment gateway (Colombia)
# IMPORTANTE: NEXT_PUBLIC_* se hornea en build time. Tras cambiar estas vars hay
# que reconstruir el frontend (npm run build) y reiniciar el service — editar el
# .env en caliente NO surte efecto.
# El entorno (URL + public key) DEBE coincidir con el del backend
# (WOMPI_API_URL / WOMPI_PUBLIC_KEY). No mezclar sandbox con producción:
#   - Sandbox:    NEXT_PUBLIC_WOMPI_API_URL=https://sandbox.wompi.co/v1    + pub_test_...
#   - Producción: NEXT_PUBLIC_WOMPI_API_URL=https://production.wompi.co/v1 + pub_prod_...
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WOMPI_API_URL=https://sandbox.wompi.co/v1
